    Future<List<DayRecord>> loadDataOfYear(String year) async {
        // 加载某一年的全部数据

        List<String> dates = [];
        Map<String, dynamic> jsonData = {};

        // 读取文件内容
        File file = File('./${year}.json');
        try {
            String contents = await file.readAsString();
            jsonData = json.decode(contents);
            dates = jsonData.keys.toList();
        } catch (e) {
            print('== loadDataOfYear error: $e');
        }

        // 初始化
        List<DayRecord> data = List.generate(dates.length, (i) => DayRecord(dates[i], jsonData[dates[i]], configLoader));
        return data;
    }

    Future<List<DayRecord>> loadCacheData() async {
        // 启动的时候使用的，准备好当前时间点前7天、后两天的数据。如果前7天的时间在数据里找不到，那就得凑齐空白的补上
        const int cacheDataDayCount = 7;
        List<String> dates = [];
        Map<String, dynamic> jsonData = {};
        List<DayRecord> data = [];

        // 当前日期（按照yyyMMdd的格式）
        String currentDate = formatter.format(DateTime.now());

        // 读取文件内容
        File file = File('./${currentDate.substring(0,4)}.json');
        try {
            String contents = await file.readAsString();
            jsonData = json.decode(contents);
            dates = jsonData.keys.toList();            
        } catch (e) {
            print('== loadDataOfYear error: $e');
        }

        // 如果加载的数据里最新日期不是今天，需要给jsonData添加上直到今天为止每一天的空白DayBlockData作为占位
        // jsonData是加了，是不是还该异步把数据写入到json文件里？
        int missingDays = int.parse(currentDate) - int.parse(dates.last);
        if (missingDays < 0){ // 在未来还有记录：加载过去七天和未来全部的记录，再额外补两天
            data.addAll(List.generate(cacheDataDayCount, (i) => DayRecord(dates.sublist(dates.length - cacheDataDayCount + missingDays)[i], jsonData[dates[i]], configLoader)));
            data.addAll(createEmptyDayRecords(dates.last, missingDays+2)); // 默认加两天的空白作为未来情况
        }else if (missingDays < cacheDataDayCount){ // 在过去7天内有记录：加载过去7天内的全部记录，缺失的就补空白的
            // todo: 这里的历史数据加载似乎有问题
            data.addAll(List.generate(cacheDataDayCount-missingDays, (i) => DayRecord(dates.sublist(dates.length - cacheDataDayCount)[i], jsonData[dates[i]], configLoader)));
            data.addAll(createEmptyDayRecords(dates.last, missingDays+2)); // 默认加两天的空白作为未来情况
        }else{ // 过去7天是一点数据没有：那就创造7天的空白数据，另外给历史数据补空白数据到当前
            // 如果当前时间距离上次记录的时间超过了cacheData的天数限制，则cacheData全是空DayRecord
            data.addAll(createEmptyDayRecords((int.parse(currentDate) - 1).toString(), cacheDataDayCount+2));// 默认加两天的空白作为未来情况。但是如果未来已经有确定的内容了，那就把未来也加载进cacheData
            // todo: 做一下补全外置json的操作
            compensateHistoryData();
        }

        return data;
    }

    List<DayRecord> createEmptyDayRecords(String startDate, int range){
        // 创造从startDate开始后往后range这么多天的空白日期记录
        List<int> dates = List.generate(range-1, (i) => int.parse(startDate)+i); // range是1才有1个DayRecord，是0的话就一天都没有了
        List<DayRecord> record = List.generate(range, (i) => DayRecord(dates[i].toString(), [], configLoader));

        return record;
    }

    void compensateHistoryData(){

    }

