class ConfigLoader extends ChangeNotifier {
    List<EventInfo> eventInfos = [];
    // Map<String, dynamic> jsonData = {};

    ConfigLoader() {
        File file = File('lib/config.json');
        print("== file: ${file.path}");
        loadFileAsJson(file);
    }

    Future<void> loadFileAsJson(File file) async {
        // Map<String, dynamic> jsonData = {};
        eventInfos.clear();
        String contents = await file.readAsString();
        Map<String, dynamic> jsonData = json.decode(contents);
        for(var info in jsonData["eventInfo"].toList()){
            // print("== loadFileAsJson_config, ${info}");
            try{
                // print("== loadFileAsJson_config, ${info[0].runtimeType},  ${info[1].runtimeType}, ${info[2].runtimeType}, ${info[3].runtimeType}");
                eventInfos.add(EventInfo(info[0], info[1], info[2]));
            }catch(e){
                // print("== loadFileAsJson error: $e");
            }
        }
    }

    Color getBlockColorByEventType(String eventType){
        // 根据eventType返回对应的颜色
        for (var info in eventInfos){
            if (info.name == eventType){
                return info.color;
            }
        }
        return Color.fromRGBO(0, 0, 0, 1);
    }

}

