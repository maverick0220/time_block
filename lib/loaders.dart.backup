    DataLoader(this.configLoader) {
        // 不应该是简单粗暴直接加载当前年的全部数据，应该是准备好cacheData（全年数据可以异步加载
        DateTime fileDate = DateTime.now();
        print("== file: ${fileDate.year}.json");
        File file = File('${fileDate.year}.json');
        // Map<String, dynamic> jsonData = {};
        loadFileAsJson(file);
    }

    Future<void> loadFileAsJson(File file) async {
        dayRecords.clear();

        file.readAsString().then((contents) {
            if (contents == "") {
                return;
            }

            var jsonData = jsonDecode(contents); // 如果输入是空字符串，这玩意儿居然会直接报错
            for(var date in jsonData.keys.toList()){
                // print("date: ${date}");
                // print("jsonData[date]: ${jsonData[date]}");
                try{
                    dayRecords.add(DayRecord(date, jsonData[date], configLoader));
                }catch(e){
                    print("== loadFileAsJson error: $e, ${date}");
                }
            }
        });

        // rootBundle.loadString('asserts/name_data.json').then((value) {
        //   contents = json.decode(value);
        // });

        
        print("== loadFileAsJson dayRecords.length: ${dayRecords.length}");
    }


    // void addDate(){
